{
  "name": "mnemo-vscode",
  "displayName": "Mnemo",
  "description": "Persistent memory, semantic code search, cross-repo intelligence, and architecture awareness for AI coding assistants. Works with Amazon Q, Cursor, Claude Code, Copilot, and any MCP client.",
  "version": "0.4.0",
  "publisher": "Nikhil1057",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mnemo-mcp/Mnemo"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["AI", "Programming Languages", "Other"],
  "icon": "icon.png",
  "keywords": ["mnemo", "mcp", "ai", "memory", "code-intelligence", "semantic-search", "amazon-q", "cursor", "claude", "copilot", "architecture", "cross-repo"],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {"command": "mnemo.initWorkspace", "title": "Mnemo: Initialize Workspace"},
      {"command": "mnemo.showStatus", "title": "Mnemo: Show Status"},
      {"command": "mnemo.refreshIndex", "title": "Mnemo: Refresh Index"},
      {"command": "mnemo.resetWorkspace", "title": "Mnemo: Reset (Wipe All Memory)"},
      {"command": "mnemo.detectInstall", "title": "Mnemo: Check Installation"}
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.5.4"
  }
}
